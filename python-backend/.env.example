OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-plus
TEMPERATURE=0.7
MAX_MEMORY_MESSAGES=10
DATABASE_URL=sqlite:///./data/app.db
JWT_SECRET_KEY=change-this-jwt-secret-key-min-32-bytes
JWT_EXPIRE_MINUTES=10080
RAG_ENABLED=true
RAG_DOCS_DIR=./data/docs
RAG_INDEX_DIR=./data/vector_index
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.75
EMBEDDING_MODEL=text-embedding-v4
WEB_SEARCH_ENABLED=true
BIGMODEL_API_KEY=
MCP_WEB_SEARCH_URL=https://open.bigmodel.cn/api/mcp/web_search_prime/mcp
WEB_SEARCH_TOP_K=5
GUARDRAIL_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://localhost:8081,http://127.0.0.1:3000,http://127.0.0.1:5173
